---
import defaultThumbnail from "../assets/images/thumbnal-default.png";

interface Props {
  slug: string;
  title: string;
  description: string;
  pubDate: Date;
  thumbnail?: string;
  headingLevel?: "h2" | "h3";
}

const {
  slug,
  title,
  description,
  pubDate,
  thumbnail,
  headingLevel = "h2",
} = Astro.props;

const formattedDate = pubDate.toLocaleDateString("en-GB", {
  year: "numeric",
  month: "short",
  day: "numeric",
});
const thumbnailSrc = thumbnail || defaultThumbnail.src;
const Heading = headingLevel;
---

<li class="post-item">
  <a href={`/blog/${slug}/`}>
    <div class="post-entry">
      <img
        class="post-thumbnail"
        src={thumbnailSrc}
        alt={`Thumbnail for ${title}`}
        width="450"
        height="254"
        loading="lazy"
      />
      <div class="post-content">
        <div class="post-info">
          <time datetime={pubDate.toISOString()}>{formattedDate}</time>
        </div>
        <Heading>{title}</Heading>
        <p>{description}</p>
      </div>
    </div>
  </a>
</li>

<style>
  .post-item {
    margin-bottom: 0;
    border: 1px solid var(--color-border);
    border-radius: 8px;
    overflow: hidden;
    transition: border-color var(--transition);
  }

  .post-item:hover {
    border-color: var(--color-accent);
  }

  .post-item a {
    display: block;
    color: var(--color-text);
    transition: all var(--transition);
  }

  .post-item a:hover {
    color: var(--color-text);
  }

  .post-item a:hover :global(h2),
  .post-item a:hover :global(h3) {
    color: var(--color-accent);
  }

  /* ── Card layout ── */
  .post-entry {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .post-thumbnail {
    width: 100%;
    height: 200px;
    object-fit: contain;
    background: var(--color-surface);
    border-radius: 0;
  }

  .post-content {
    flex: 1;
    min-width: 0;
    padding: 0.625rem 0.75rem;
  }

  .post-info {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 0.375rem;
    flex-wrap: wrap;
  }

  .post-info time {
    font-family: var(--font-mono);
    font-size: 0.8125rem;
    color: var(--color-text-muted);
  }

  .post-item :global(h2),
  .post-item :global(h3) {
    font-size: 0.9375rem;
    font-weight: 600;
    margin: 0 0 0.25rem;
    transition: color var(--transition);
  }

  .post-item p {
    font-size: 0.8125rem;
    color: var(--color-text-muted);
    line-height: 1.4;
    margin: 0;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>
