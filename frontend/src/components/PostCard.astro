---
import defaultThumbnail from "../assets/images/thumbnal-default.png";

interface Props {
  slug: string;
  title: string;
  description: string;
  pubDate: Date;
  thumbnail?: string;
  tags?: string[];
  showTags?: boolean;
  headingLevel?: "h2" | "h3";
}

const {
  slug,
  title,
  description,
  pubDate,
  thumbnail,
  tags = [],
  showTags = false,
  headingLevel = "h2",
} = Astro.props;

const formattedDate = pubDate.toLocaleDateString("en-GB", {
  year: "numeric",
  month: "short",
  day: "numeric",
});
const thumbnailSrc = thumbnail || defaultThumbnail.src;
const Heading = headingLevel;
---

<li class="post-item">
  <a href={`/blog/${slug}/`}>
    <div class="post-entry">
      <img
        class="post-thumbnail"
        src={thumbnailSrc}
        alt={`Thumbnail for ${title}`}
        width="450"
        height="254"
        loading="lazy"
      />
      <div class="post-content">
        <div class="post-info">
          <time datetime={pubDate.toISOString()}>{formattedDate}</time>
          {showTags && tags.length > 0 && (
            <div class="post-tags">
              {tags.slice(0, 3).map((tag) => (
                <span class="tag">#{tag}</span>
              ))}
            </div>
          )}
        </div>
        <Heading>{title}</Heading>
        <p>{description}</p>
      </div>
    </div>
  </a>
</li>

<style>
  .post-item {
    margin-bottom: 0;
    border-bottom: 1px solid var(--color-border);
  }

  .post-item:first-child {
    border-top: 1px solid var(--color-border);
  }

  .post-item a {
    display: block;
    padding: 1.25rem 0;
    color: var(--color-text);
    transition: all var(--transition);
  }

  .post-item a:hover {
    color: var(--color-text);
  }

  .post-item a:hover :global(h2),
  .post-item a:hover :global(h3) {
    color: var(--color-accent);
  }

  /* ── Card layout ── */
  .post-entry {
    display: flex;
    align-items: flex-start;
    gap: 1.25rem;
  }

  .post-thumbnail {
    width: 450px;
    height: auto;
    flex-shrink: 0;
    border-radius: 6px;
  }

  .post-content {
    flex: 1;
    min-width: 0;
  }

  .post-info {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 0.375rem;
  }

  .post-info time {
    font-family: var(--font-mono);
    font-size: 0.8125rem;
    color: var(--color-text-muted);
  }

  .post-tags {
    display: flex;
    gap: 0.375rem;
  }

  .tag {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--color-accent);
    opacity: 0.7;
  }

  .post-item :global(h2),
  .post-item :global(h3) {
    font-size: 1.25rem;
    font-weight: 600;
    margin: 0 0 0.375rem;
    transition: color var(--transition);
  }

  .post-item p {
    font-size: 0.9375rem;
    color: var(--color-text-muted);
    line-height: 1.5;
    margin: 0;
  }

  /* ── Responsive: stack thumbnail above text ── */
  @media (max-width: 480px) {
    .post-entry {
      flex-direction: column;
      gap: 0.75rem;
    }

    .post-thumbnail {
      width: 100%;
      max-height: 350px;
      border-radius: 6px;
    }
  }
</style>
