---
import type { CollectionEntry } from "astro:content";
import BaseLayout from "./BaseLayout.astro";
import SocialLinks from "../components/SocialLinks.astro";
import GalleryButton from "../components/GalleryButton.astro";
import Gallery from "../components/Gallery.astro";

interface Props {
  post: CollectionEntry<"blog">;
}

const { post } = Astro.props;
const { title, description, pubDate, updatedDate, heroImage, heroFit } = post.data;
const hasGallery = !!post.data.gallery;

// Normalise heroImage to always be an array for rendering
const heroImages = heroImage
  ? Array.isArray(heroImage) ? heroImage : [heroImage]
  : [];
// Use the first image for OG/meta tags
const ogImage = heroImages[0];

const formattedDate = pubDate.toLocaleDateString("en-GB", {
  year: "numeric",
  month: "long",
  day: "numeric",
});

const formattedUpdatedDate = updatedDate?.toLocaleDateString("en-GB", {
  year: "numeric",
  month: "long",
  day: "numeric",
});
---

<BaseLayout title={`${title} — Omar Maaouane`} description={description} image={ogImage}>
  <article class="blog-post">
    <header class="post-header">
      <div class="post-meta">
        <time datetime={pubDate.toISOString()}>{formattedDate}</time>
        {updatedDate && (
          <span class="updated">
            · Updated <time datetime={updatedDate.toISOString()}>{formattedUpdatedDate}</time>
          </span>
        )}
      </div>
      <h1>{title}</h1>
      {description && <p class="post-description">{description}</p>}
    </header>

    {heroImages.length > 0 && (
      <div class:list={["hero-images", { "hero-images--multi": heroImages.length > 1 }]}>
        {heroImages.map((src) => (
          <img
            class:list={["hero-image", { "hero-image--contain": heroFit === "contain" }]}
            src={src}
            alt={`Hero image for ${title}`}
            width="720"
            height="360"
          />
        ))}
      </div>
    )}

    <div class="post-content">
      <slot />
    </div>

    {hasGallery && <GalleryButton />}

    <footer class="post-footer">
      <a href="/blog" class="back-link">&larr; Back to all posts</a>

      <div class="post-footer-socials">
        <p class="connect-label">Connect with me</p>
        <SocialLinks size={18} />
      </div>
    </footer>

    {hasGallery && <Gallery folder={post.data.gallery!} />}
  </article>
</BaseLayout>

<style>
  .blog-post {
    max-width: 100%;
  }

  .post-header {
    margin-bottom: 2.5rem;
    padding-bottom: 2rem;
    border-bottom: 1px solid var(--color-border);
  }

  .post-meta {
    font-size: 0.875rem;
    color: var(--color-text-muted);
    font-family: var(--font-mono);
    margin-bottom: 0.75rem;
  }

  .post-meta .updated {
    color: var(--color-text-muted);
  }

  .post-header h1 {
    font-size: 2rem;
    margin-bottom: 0.75rem;
    letter-spacing: -0.03em;
  }

  .post-description {
    font-size: 1.125rem;
    color: var(--color-text-muted);
    line-height: 1.6;
    margin-bottom: 1rem;
  }

  .hero-images {
    margin-bottom: 2.5rem;
  }

  .hero-images--multi {
    display: flex;
    gap: 0.75rem;
    justify-content: center;
  }

  .hero-images--multi .hero-image {
    flex: 1 1 0;
    min-width: 0;
    max-height: 60vh;
    object-fit: cover;
  }

  .hero-image {
    width: 100%;
    height: auto;
    border-radius: 8px;
    border: 1px solid var(--color-border);
  }

  .hero-image--contain {
    max-height: 60vh;
    width: auto;
    max-width: 100%;
    object-fit: contain;
    display: block;
    margin-left: auto;
    margin-right: auto;
  }

  .post-content {
    font-size: 1.0625rem;
    line-height: 1.8;
    padding: 0 1rem;
  }

  .post-footer {
    margin-top: 3rem;
    padding-top: 2rem;
    border-top: 1px solid var(--color-border);
  }

  .back-link {
    font-family: var(--font-mono);
    font-size: 0.875rem;
    color: var(--color-text-muted);
    transition: color var(--transition);
  }

  .back-link:hover {
    color: var(--color-accent);
  }

  .post-footer-socials {
    margin-top: 1.5rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--color-border);
  }

  .connect-label {
    font-family: var(--font-mono);
    font-size: 0.8125rem;
    color: var(--color-text-muted);
    margin-bottom: 0.75rem;
  }

  /* Media embed utility classes */
  .post-content :global(.media-embed) {
    display: flex;
    gap: 1.5rem;
    align-items: flex-start;
    margin: 1.5rem 0;
  }

  /* Alternate direction: even embeds flip media to the right */
  .post-content :global(.media-embed:nth-of-type(even)) {
    flex-direction: row-reverse;
  }

  .post-content :global(.media-embed__media) {
    flex: 1 1 0;
    min-width: 0;
    overflow: hidden;
  }

  .post-content :global(.media-embed__media video),
  .post-content :global(.media-embed__media img) {
    width: 100%;
    object-fit: contain;
  }

  .post-content :global(.media-embed__media iframe) {
    width: 100%;
    min-height: 700px;
    border: none;
    margin-bottom: 0.75rem;
  }

  .post-content :global(.media-embed__caption) {
    flex: 1 1 0;
    min-width: 0;
    background: var(--color-bg);
    padding: 1.25rem;
    border-radius: 8px;
    border: 1px solid var(--color-border);
  }

  @media (max-width: 640px) {
    .post-content :global(.media-embed) {
      flex-direction: column;
    }
    .post-content :global(.media-embed:nth-of-type(even)) {
      flex-direction: column;
    }
  }

  /* Link card styles */
  .post-content :global(.link-card) {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 1rem 1.25rem;
    border: 1px solid var(--color-border);
    border-radius: 8px;
    background: var(--color-bg);
    text-decoration: none;
    color: inherit;
    transition: border-color var(--transition), background var(--transition);
    margin: 0.75rem 0;
  }

  .post-content :global(.link-card:hover) {
    border-color: var(--color-accent);
    background: rgba(59, 130, 246, 0.05);
  }

  .post-content :global(.link-card__icon) {
    width: 100px;
    height: 100px;
    object-fit: cover;
    border-radius: 6px;
    border: 1px solid var(--color-border);
    flex-shrink: 0;
  }

  .post-content :global(.link-card__content) {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    min-width: 0;
    flex: 1;
  }

  .post-content :global(.link-card__title) {
    font-weight: 600;
    font-size: 0.9375rem;
    color: var(--color-accent);
  }

  .post-content :global(.link-card__description) {
    font-size: 0.8125rem;
    color: var(--color-text-muted);
    line-height: 1.4;
  }

  .post-content :global(.link-card__domain) {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--color-text-muted);
    opacity: 0.7;
  }

  .post-content :global(.link-card__arrow) {
    font-size: 1.25rem;
    color: var(--color-text-muted);
    flex-shrink: 0;
    transition: color var(--transition);
  }

  .post-content :global(.link-card:hover .link-card__arrow) {
    color: var(--color-accent);
  }

  /* Download card styles */
  .post-content :global(.download-card) {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 1rem 1.25rem;
    border: 1px solid var(--color-border);
    border-radius: 8px;
    background: var(--color-bg);
    text-decoration: none;
    color: inherit;
    transition: border-color var(--transition), background var(--transition);
    margin: 0.75rem 0;
  }

  .post-content :global(.download-card:hover) {
    border-color: var(--color-accent);
    background: rgba(59, 130, 246, 0.05);
  }

  .post-content :global(.download-card__thumb) {
    width: 80px;
    align-self: stretch;
    object-fit: contain;
    border-radius: 6px;
    border: 1px solid var(--color-border);
    flex-shrink: 0;
  }

  .post-content :global(.download-card__content) {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    min-width: 0;
    flex: 1;
  }

  .post-content :global(.download-card__title) {
    font-weight: 600;
    font-size: 0.9375rem;
    color: var(--color-accent);
  }

  .post-content :global(.download-card__description) {
    font-size: 0.8125rem;
    color: var(--color-text-muted);
    line-height: 1.4;
  }

  .post-content :global(.download-card__filename) {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--color-text-muted);
    opacity: 0.7;
  }

  .post-content :global(.download-card__icon) {
    font-size: 1.25rem;
    color: var(--color-text-muted);
    flex-shrink: 0;
    transition: color var(--transition), transform var(--transition);
  }

  .post-content :global(.download-card:hover .download-card__icon) {
    color: var(--color-accent);
    transform: translateY(2px);
  }

  @media (max-width: 640px) {
    .post-header h1 {
      font-size: 1.5rem;
    }

    .post-description {
      font-size: 1rem;
    }

    .post-content {
      font-size: 1rem;
    }
  }
</style>
