---
import type { CollectionEntry } from "astro:content";
import BaseLayout from "./BaseLayout.astro";
import SocialLinks from "../components/SocialLinks.astro";

interface Props {
  post: CollectionEntry<"blog">;
}

const { post } = Astro.props;
const { title, description, pubDate, updatedDate, heroImage, tags } = post.data;

const formattedDate = pubDate.toLocaleDateString("en-GB", {
  year: "numeric",
  month: "long",
  day: "numeric",
});

const formattedUpdatedDate = updatedDate?.toLocaleDateString("en-GB", {
  year: "numeric",
  month: "long",
  day: "numeric",
});
---

<BaseLayout title={`${title} — Omar Maaouane`} description={description} image={heroImage}>
  <article class="blog-post">
    <header class="post-header">
      <div class="post-meta">
        <time datetime={pubDate.toISOString()}>{formattedDate}</time>
        {updatedDate && (
          <span class="updated">
            · Updated <time datetime={updatedDate.toISOString()}>{formattedUpdatedDate}</time>
          </span>
        )}
      </div>
      <h1>{title}</h1>
      {description && <p class="post-description">{description}</p>}
      {tags.length > 0 && (
        <div class="post-tags">
          {tags.map((tag) => (
            <span class="tag">#{tag}</span>
          ))}
        </div>
      )}
    </header>

    {heroImage && (
      <img
        class="hero-image"
        src={heroImage}
        alt={`Hero image for ${title}`}
        width="720"
        height="360"
      />
    )}

    <div class="post-content">
      <slot />
    </div>

    <footer class="post-footer">
      <a href="/blog" class="back-link">&larr; Back to all posts</a>

      <div class="post-footer-socials">
        <p class="connect-label">Connect with me</p>
        <SocialLinks size={18} />
      </div>
    </footer>
  </article>
</BaseLayout>

<style>
  .blog-post {
    max-width: 100%;
  }

  .post-header {
    margin-bottom: 2.5rem;
    padding-bottom: 2rem;
    border-bottom: 1px solid var(--color-border);
  }

  .post-meta {
    font-size: 0.875rem;
    color: var(--color-text-muted);
    font-family: var(--font-mono);
    margin-bottom: 0.75rem;
  }

  .post-meta .updated {
    color: var(--color-text-muted);
  }

  .post-header h1 {
    font-size: 2rem;
    margin-bottom: 0.75rem;
    letter-spacing: -0.03em;
  }

  .post-description {
    font-size: 1.125rem;
    color: var(--color-text-muted);
    line-height: 1.6;
    margin-bottom: 1rem;
  }

  .post-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .tag {
    font-family: var(--font-mono);
    font-size: 0.8125rem;
    color: var(--color-accent);
    background: rgba(59, 130, 246, 0.1);
    padding: 0.2em 0.6em;
    border-radius: 4px;
  }

  .hero-image {
    width: 100%;
    height: auto;
    border-radius: 8px;
    margin-bottom: 2.5rem;
    border: 1px solid var(--color-border);
  }

  .post-content {
    font-size: 1.0625rem;
    line-height: 1.8;
    padding: 0 1rem;
  }

  .post-footer {
    margin-top: 3rem;
    padding-top: 2rem;
    border-top: 1px solid var(--color-border);
  }

  .back-link {
    font-family: var(--font-mono);
    font-size: 0.875rem;
    color: var(--color-text-muted);
    transition: color var(--transition);
  }

  .back-link:hover {
    color: var(--color-accent);
  }

  .post-footer-socials {
    margin-top: 1.5rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--color-border);
  }

  .connect-label {
    font-family: var(--font-mono);
    font-size: 0.8125rem;
    color: var(--color-text-muted);
    margin-bottom: 0.75rem;
  }

  /* Media embed utility classes */
  .post-content :global(.media-embed) {
    display: flex;
    gap: 1.5rem;
    align-items: flex-start;
    margin: 1.5rem 0;
  }

  /* Alternate direction: even embeds flip media to the right */
  .post-content :global(.media-embed:nth-of-type(even)) {
    flex-direction: row-reverse;
  }

  .post-content :global(.media-embed__media) {
    flex: 1 1 0;
    min-width: 0;
    overflow: hidden;
  }

  .post-content :global(.media-embed__media video),
  .post-content :global(.media-embed__media img) {
    width: 100%;
    object-fit: contain;
  }

  .post-content :global(.media-embed__media iframe) {
    width: 100%;
    min-height: 700px;
    border: none;
    margin-bottom: 0.75rem;
  }

  .post-content :global(.media-embed__caption) {
    flex: 1 1 0;
    min-width: 0;
    background: var(--color-bg);
    padding: 1.25rem;
    border-radius: 8px;
    border: 1px solid var(--color-border);
  }

  @media (max-width: 640px) {
    .post-content :global(.media-embed) {
      flex-direction: column;
    }
    .post-content :global(.media-embed:nth-of-type(even)) {
      flex-direction: column;
    }
  }

  /* Link card styles */
  .post-content :global(.link-card) {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding: 1rem 1.25rem;
    border: 1px solid var(--color-border);
    border-radius: 8px;
    background: var(--color-bg);
    text-decoration: none;
    color: inherit;
    transition: border-color var(--transition), background var(--transition);
    margin: 0.75rem 0;
  }

  .post-content :global(.link-card:hover) {
    border-color: var(--color-accent);
    background: rgba(59, 130, 246, 0.05);
  }

  .post-content :global(.link-card__content) {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    min-width: 0;
  }

  .post-content :global(.link-card__title) {
    font-weight: 600;
    font-size: 0.9375rem;
    color: var(--color-accent);
  }

  .post-content :global(.link-card__description) {
    font-size: 0.8125rem;
    color: var(--color-text-muted);
    line-height: 1.4;
  }

  .post-content :global(.link-card__domain) {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--color-text-muted);
    opacity: 0.7;
  }

  .post-content :global(.link-card__arrow) {
    font-size: 1.25rem;
    color: var(--color-text-muted);
    flex-shrink: 0;
    transition: color var(--transition);
  }

  .post-content :global(.link-card:hover .link-card__arrow) {
    color: var(--color-accent);
  }

  @media (max-width: 640px) {
    .post-header h1 {
      font-size: 1.5rem;
    }

    .post-description {
      font-size: 1rem;
    }

    .post-content {
      font-size: 1rem;
    }
  }
</style>
