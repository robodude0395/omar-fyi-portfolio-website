---
import BaseLayout from "../layouts/BaseLayout.astro";
import PostCard from "../components/PostCard.astro";
import { getPublishedPosts, getFeaturedPosts } from "../utils/posts";

const featured = await getFeaturedPosts(3);
const posts = (await getPublishedPosts()).slice(0, 3);
---

<BaseLayout title="Omar Maaouane Veiga —  Software Engineer and Eclectic Human Being">
  <section class="hero">
    <div class="hero-content">
      <div class="hero-text">
        <p class="greeting">Hey, I'm</p>
        <h1>Omar Maaouane Veiga</h1>
        <p class="tagline">
          I solve complex problems through data analysis.
          Applying the same mindset to software systems and physical hardware.
          Passionate about building things that make a difference.
        </p>
        <div class="hero-links">
          <a href="/blog" class="hero-link primary">Read the blog &rarr;</a>
          <a href="/about" class="hero-link secondary">More about me</a>
        </div>
      </div>
      <div class="hero-photo">
        <a href="/about" aria-label="Learn more about Omar">
          <img src="/media/Omar_Hero.png" alt="Omar Maaouane Veiga" width="280" height="280" />
        </a>
      </div>
    </div>
  </section>

  {featured.length > 0 && (
    <section class="featured-posts">
      <h2>Featured</h2>
      <ul class="post-list">
        {featured.map((post) => (
          <PostCard
            slug={post.slug}
            title={post.data.title}
            description={post.data.description}
            pubDate={post.data.pubDate}
            thumbnail={post.data.thumbnail}
            headingLevel="h3"
          />
        ))}
      </ul>
    </section>
  )}

  {posts.length > 0 && (
    <section class="recent-posts">
      <h2>Recent posts</h2>
      <ul class="post-list">
        {posts.map((post) => (
          <PostCard
            slug={post.slug}
            title={post.data.title}
            description={post.data.description}
            pubDate={post.data.pubDate}
            thumbnail={post.data.thumbnail}
            headingLevel="h3"
          />
        ))}
      </ul>
      <a href="/blog" class="view-all">View all posts &rarr;</a>
    </section>
  )}
</BaseLayout>

<style>
  /* ── Hero ── */
  .hero {
    padding: 4rem 0 3rem;
  }

  .hero-content {
    display: flex;
    align-items: center;
    gap: 3rem;
  }

  .hero-text {
    flex: 1;
  }

  .hero-photo {
    flex-shrink: 0;
  }

  .hero-photo img {
    width: 280px;
    height: 280px;
    border-radius: 50%;
    object-fit: cover;
    border: 3px solid var(--color-border);
    transition: border-color var(--transition);
  }

  .hero-photo img:hover {
    border-color: var(--color-accent);
  }

  .greeting {
    font-family: var(--font-mono);
    font-size: 1rem;
    color: var(--color-text-muted);
    margin-bottom: 0.5rem;
  }

  .hero h1 {
    font-size: 3rem;
    font-weight: 700;
    letter-spacing: -0.04em;
    margin-bottom: 1.25rem;
  }

  .tagline {
    font-size: 1.25rem;
    color: var(--color-text-muted);
    line-height: 1.6;
    max-width: 640px;
    margin-bottom: 2rem;
  }

  .hero-links {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .hero-link {
    font-family: var(--font-mono);
    font-size: 0.9375rem;
    padding: 0.625rem 1.25rem;
    border-radius: 6px;
    transition: all var(--transition);
  }

  .hero-link.primary {
    background: var(--color-accent);
    color: #fff;
  }

  .hero-link.primary:hover {
    background: var(--color-accent-hover);
    color: #fff;
  }

  .hero-link.secondary {
    border: 1px solid var(--color-border);
    color: var(--color-text-muted);
  }

  .hero-link.secondary:hover {
    border-color: var(--color-text-muted);
    color: var(--color-text);
  }

  /* ── Featured Posts ── */
  .featured-posts {
    padding: 2rem 0;
    border-top: 1px solid var(--color-border);
  }

  .featured-posts h2 {
    font-size: 1.25rem;
    font-family: var(--font-mono);
    font-weight: 600;
    margin-bottom: 1.5rem;
    margin-top: 0;
  }

  /* ── Recent Posts ── */
  .recent-posts {
    padding: 2rem 0;
    border-top: 1px solid var(--color-border);
  }

  .recent-posts h2 {
    font-size: 1.25rem;
    font-family: var(--font-mono);
    font-weight: 600;
    margin-bottom: 1.5rem;
    margin-top: 0;
  }

  .post-list {
    list-style: none;
    padding: 0;
    margin: 0 0 1.5rem;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.25rem;
  }

  @media (max-width: 768px) {
    .post-list {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 480px) {
    .post-list {
      grid-template-columns: 1fr;
    }
  }

  .view-all {
    font-family: var(--font-mono);
    font-size: 0.875rem;
    color: var(--color-text-muted);
    transition: color var(--transition);
  }

  .view-all:hover {
    color: var(--color-accent);
  }

  @media (max-width: 768px) {
    .hero-content {
      flex-direction: column-reverse;
      text-align: center;
      gap: 2rem;
    }

    .hero-photo img {
      width: 200px;
      height: 200px;
    }

    .hero-links {
      justify-content: center;
    }

    .tagline {
      margin-left: auto;
      margin-right: auto;
    }
  }

  @media (max-width: 640px) {
    .hero {
      padding: 2rem 0;
    }

    .hero h1 {
      font-size: 2.25rem;
    }

    .tagline {
      font-size: 1.0625rem;
    }
  }
</style>
