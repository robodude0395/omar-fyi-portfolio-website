---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import defaultThumbnail from "../assets/images/thumbnal-default.png";

const posts = (await getCollection("blog"))
  .filter((post) => !post.data.draft)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);
---

<BaseLayout title="Omar Maaouane Veiga —  Software Engineer and Eclectic Human Being">
  <section class="hero">
    <div class="hero-content">
      <div class="hero-text">
        <p class="greeting">Hey, I'm</p>
        <h1>Omar Maaouane Veiga</h1>
        <p class="tagline">
          I solve complex problems through data analysis.
          Applying the same mindset to software systems and physical hardware.
          Passionate about building things that make a difference.
        </p>
        <div class="hero-links">
          <a href="/blog" class="hero-link primary">Read the blog &rarr;</a>
          <a href="/about" class="hero-link secondary">More about me</a>
        </div>
      </div>
      <div class="hero-photo">
        <img src="/media/Omar_Hero.png" alt="Omar Maaouane Veiga" width="280" height="280" />
      </div>
    </div>
  </section>

  {posts.length > 0 && (
    <section class="recent-posts">
      <h2>Recent posts</h2>
      <ul class="post-list">
        {posts.map((post) => {
          const formattedDate = post.data.pubDate.toLocaleDateString("en-GB", {
            year: "numeric",
            month: "short",
            day: "numeric",
          });
          const thumbnailSrc = post.data.thumbnail || defaultThumbnail.src;
          return (
            <li class="post-item">
              <a href={`/blog/${post.slug}/`}>
                <div class="post-entry">
                  <img
                    class="post-thumbnail"
                    src={thumbnailSrc}
                    alt={`Thumbnail for ${post.data.title}`}
                    width="80"
                    height="80"
                    loading="lazy"
                  />
                  <div class="post-content">
                    <time datetime={post.data.pubDate.toISOString()}>
                      {formattedDate}
                    </time>
                    <h3>{post.data.title}</h3>
                    <p>{post.data.description}</p>
                  </div>
                </div>
              </a>
            </li>
          );
        })}
      </ul>
      <a href="/blog" class="view-all">View all posts &rarr;</a>
    </section>
  )}
</BaseLayout>

<style>
  /* ── Hero ── */
  .hero {
    padding: 4rem 0 3rem;
  }

  .hero-content {
    display: flex;
    align-items: center;
    gap: 3rem;
  }

  .hero-text {
    flex: 1;
  }

  .hero-photo {
    flex-shrink: 0;
  }

  .hero-photo img {
    width: 280px;
    height: 280px;
    border-radius: 50%;
    object-fit: cover;
    border: 3px solid var(--color-border);
    transition: border-color var(--transition);
  }

  .hero-photo img:hover {
    border-color: var(--color-accent);
  }

  .greeting {
    font-family: var(--font-mono);
    font-size: 1rem;
    color: var(--color-accent);
    margin-bottom: 0.5rem;
  }

  .hero h1 {
    font-size: 3rem;
    font-weight: 700;
    letter-spacing: -0.04em;
    margin-bottom: 1.25rem;
  }

  .tagline {
    font-size: 1.25rem;
    color: var(--color-text-muted);
    line-height: 1.6;
    max-width: 640px;
    margin-bottom: 2rem;
  }

  .hero-links {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .hero-link {
    font-family: var(--font-mono);
    font-size: 0.9375rem;
    padding: 0.625rem 1.25rem;
    border-radius: 6px;
    transition: all var(--transition);
  }

  .hero-link.primary {
    background: var(--color-accent);
    color: #fff;
  }

  .hero-link.primary:hover {
    background: var(--color-accent-hover);
    color: #fff;
  }

  .hero-link.secondary {
    border: 1px solid var(--color-border);
    color: var(--color-text-muted);
  }

  .hero-link.secondary:hover {
    border-color: var(--color-text-muted);
    color: var(--color-text);
  }

  /* ── Recent Posts ── */
  .recent-posts {
    padding: 2rem 0;
    border-top: 1px solid var(--color-border);
  }

  .recent-posts h2 {
    font-size: 1.25rem;
    font-family: var(--font-mono);
    font-weight: 600;
    margin-bottom: 1.5rem;
    margin-top: 0;
  }

  .post-list {
    list-style: none;
    padding: 0;
    margin: 0 0 1.5rem;
  }

  .post-item {
    margin-bottom: 0;
    border-bottom: 1px solid var(--color-border);
  }

  .post-item:first-child {
    border-top: 1px solid var(--color-border);
  }

  .post-item a {
    display: block;
    padding: 1.25rem 0;
    color: var(--color-text);
    transition: all var(--transition);
  }

  .post-item a:hover {
    color: var(--color-text);
  }

  .post-item a:hover h3 {
    color: var(--color-accent);
  }

  /* ── Thumbnail layout ── */
  .post-entry {
    display: flex;
    align-items: flex-start;
    gap: 1rem;
  }

  .post-thumbnail {
    width: 300px;
    height: 300px;
    flex-shrink: 0;
    border-radius: 6px;
    object-fit: cover;
    background-color: var(--color-border, #1a1a2e);
  }

  .post-content {
    flex: 1;
    min-width: 0;
  }

  .post-item time {
    font-family: var(--font-mono);
    font-size: 0.8125rem;
    color: var(--color-text-muted);
  }

  .post-item h3 {
    font-size: 1.125rem;
    font-weight: 600;
    margin: 0.25rem 0 0.375rem;
    transition: color var(--transition);
  }

  .post-item p {
    font-size: 0.9375rem;
    color: var(--color-text-muted);
    line-height: 1.5;
    margin: 0;
  }

  .view-all {
    font-family: var(--font-mono);
    font-size: 0.875rem;
    color: var(--color-text-muted);
    transition: color var(--transition);
  }

  .view-all:hover {
    color: var(--color-accent);
  }

  @media (max-width: 768px) {
    .hero-content {
      flex-direction: column-reverse;
      text-align: center;
      gap: 2rem;
    }

    .hero-photo img {
      width: 200px;
      height: 200px;
    }

    .hero-links {
      justify-content: center;
    }

    .tagline {
      margin-left: auto;
      margin-right: auto;
    }
  }

  @media (max-width: 640px) {
    .hero {
      padding: 2rem 0;
    }

    .hero h1 {
      font-size: 2.25rem;
    }

    .tagline {
      font-size: 1.0625rem;
    }
  }

  @media (max-width: 480px) {
    .post-entry {
      flex-direction: column;
      gap: 0.75rem;
    }

    .post-thumbnail {
      width: 100%;
      height: 300px;
      border-radius: 6px;
    }
  }
</style>
